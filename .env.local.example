# ────────────────────────────────────────────────────────
# HelloRecipes — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ────────────────────────────────────────────────────────

# Supabase — find these in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key — for the import script only (server-side)
# Find in: Supabase Dashboard > Project Settings > API > service_role key
# ⚠️  NEVER expose this key to the browser or commit it to git
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Public URL of your app (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
